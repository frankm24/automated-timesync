# Required secrets/constants (shared across all mappings)
CLOCKIFY_API_KEY=
TOGGL_API_TOKEN=
TOGGL_ORGANIZATION_ID=
TOGGL_WORKSPACE_ID=

# Optional. Leave commented unless overriding the defaults.
# TIME_SYNC_CONFIG_FILE points to the [[workspaces]] mapping TOML.
#   Default: ./time-sync.toml (the systemd unit overrides to /etc/time-sync/time-sync.toml)
# TIME_SYNC_STATE_FILE is where the synced-IDs cache is persisted.
#   Default: ~/.local/state/time-sync/state.json (systemd overrides to /var/lib/time-sync/state.json)
# TIME_SYNC_CONFIG_FILE=
# TIME_SYNC_STATE_FILE=
TIME_SYNC_LOOKBACK_HOURS=24
TIME_SYNC_DRY_RUN=false
